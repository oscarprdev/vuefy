{
  "name": "@vuefy/core",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./src/index.ts"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./src/components/*.vue"
    }
  },
  "peerDependencies": {
    "@iconify/vue": "^4.0.0",
    "@vuetify/v0": "^0.1.0",
    "vue": "^3.5.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.0",
    "happy-dom": "^15.0.0",
    "vitest": "^2.0.0"
  }
}
